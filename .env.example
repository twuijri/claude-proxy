## ══════════════════════════════════════════════════════════════════════════
##  Claude Max Proxy – Environment Variables
##  cp .env.example .env
## ══════════════════════════════════════════════════════════════════════════

# 🔐 مفتاح حماية البروكسي – ستستخدمه في LiteLLM كـ api_key
# اختر أي قيمة عشوائية: openssl rand -hex 20
PROXY_API_KEY=proxy-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# 🏢 Organization ID (اختياري – اتركه فارغاً للاختيار التلقائي)
CLAUDE_ORG_ID=

# 🍪 Session Key احتياطي (اختياري – فقط إذا لم تستخدم claude-auth)
CLAUDE_SESSION_KEY=

# 🌐 المنفذ
PROXY_PORT=8080
